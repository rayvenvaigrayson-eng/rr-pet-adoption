,\"is_device_based\":false,\"passed\":false},\"371023604\":{\"name\":\"371023604\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"controls\":{\"connector_69c68b8f7afc8190af51010f6bfe8fae\":{\"email_recipient_domains\":{\"display_in_ui\":false,\"enforce\":false}},\"connector_2128aebfecb84f64a069897515042a44\":{\"email_recipient_domains\":{\"display_in_ui\":true,\"enforce\":true},\"gmail_recipient_domains\":{\"display_in_ui\":true,\"enforce\":true}},\"connector_69c53ce437208190a51498354624deaf\":{\"email_recipient_domains\":{\"enforce\":false,\"display_in_ui\":false}},\"connector_4aaab2856305417b993eca9a216aaf6e\":{\"email_recipient_domains\":{\"enforce\":false,\"display_in_ui\":false}}}},\"is_device_based\":false,\"passed\":false},\"4112666029\":{\"name\":\"4112666029\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"featured_app_ids\":[\"plugin_connector_1p_95d39881713c8191931482a62d6edff9\",\"plugin_asdk_app_69a1d78e929881919bba0dbda1f6436d\",\"plugin_connector_1p_f8509de903288191b14a160c6c5d20b0\",\"plugin_connector_1p_1a69035c238881919c4190932b2df699\",\"plugin_connector_68df038e0ba48191908c8434991bbac2\"]},\"is_device_based\":false,\"passed\":false},\"1598825633\":{\"name\":\"1598825633\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":true,\"denominator\":0},\"is_device_based\":false,\"passed\":false},\"3983178992\":{\"name\":\"3983178992\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":true},\"is_device_based\":false,\"group_name\":\"Test\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"111706139\":{\"name\":\"111706139\",\"rule_id\":\"default\",\"secondary_exposures\":[{\"gate\":\"444232970\",\"gateValue\":\"false\",\"ruleID\":\"gbNhJYZt2LT0MMPpBwPnn\"}],\"id_type\":\"userID\",\"value\":{\"loginStrategy\":\"existing_user\",\"kind\":\"social\",\"name\":\"microsoft\",\"enabled\":true,\"tempDisabled\":false},\"is_device_based\":false,\"passed\":false},\"1939873467\":{\"name\":\"1939873467\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":true},\"is_device_based\":false,\"group_name\":\"Live-only update\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enable_web_search\":false,\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\",\"user_prompt_key\":\"good_option\"},\"is_device_based\":false,\"passed\":false},\"216497991\":{\"name\":\"216497991\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"max_pinned_room_count\":2,\"sidebar_default_recent_room_row_count\":3,\"outdated_room_bootstrap_messages_count\":10,\"idle_room_navigation_timeout_s\":900,\"max_file_size_mb\":5,\"sidebar_pagination_page_size\":6},\"is_device_based\":false,\"passed\":false},\"3058946295\":{\"name\":\"3058946295\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"workspace_id\",\"value\":{\"enabled\":false},\"is_device_based\":false,\"is_in_layer\":true,\"explicit_parameters\":[\"enabled\"],\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"1181337399\":{\"name\":\"1181337399\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"disabled_math_block_types\":[\"SQL_JOIN\",\"FIRST_ORDER_ODE\",\"DEGREES_OF_FREEDOM\",\"LEARN_44_VALIDATION_RECTANGLE_AREA\"]},\"is_device_based\":true,\"passed\":false},\"1426425582\":{\"name\":\"1426425582\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":true},\"is_device_based\":false,\"group_name\":\"Live-only create\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"1165494509\":{\"name\":\"1165494509\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":true,\"tempDisabled\":false,\"loginStrategy\":\"existing_user\",\"kind\":\"username\",\"name\":\"phone_number\"},\"is_device_based\":false,\"passed\":false},\"3583985244\":{\"name\":\"3583985244\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"workspace_id\",\"value\":{\"permissions\":[{\"permission\":\"chatgpt.workspace.model.GPT-4.1.access\"},{\"permission\":\"chatgpt.workspace.model.GPT-4.1-mini.access\"},{\"permission\":\"chatgpt.workspace.model.GPT-4.5.access\"}